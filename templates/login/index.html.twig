{% extends 'base.html.twig' %}

{% block title %}Login{% endblock %}

{% block body %}
<div id="login">
    <div class="container"> {# No pongo bien la sangría para no crear code noise #}
    <h1>Please log in</h1>
    
    {% if error %}
        <div>{{ error.messageKey|trans(error.messageData, 'security') }}</div>
    {% endif %}

    {% if app.user %}
        <div>
            You are logged in as {{ app.user.email }}, <a href="{{ path('app_logout') }}">Logout</a>
        </div>
    {% endif %}
    <form action="{{ path('app_login') }}" method="post">
        <label for="username">Email:</label>
        <input type="text" id="username" name="_username" value="{{ last_username }}" 
        class="form-control" autocomplete="username" required autofocus/>

        <label for="password">Password:</label>
        <input type="password" id="password" name="_password"
        class="form-control" autocomplete="current-password" required/>

        {# If you want to control the URL the user is redirected to on success
        <input type="hidden" name="_target_path" value="/account"/> #}

        <button type="submit" class="pull-right btn btn-lg sr-button">login</button>
    </form>
    </div>
</div>
{% endblock %}
